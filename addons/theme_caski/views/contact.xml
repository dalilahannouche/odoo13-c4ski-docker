<odoo>

<template id="contact_caski" name="Design Contact" inherit_id="website.contactus">
        <xpath expr="//div[@id='wrap']" position="replace">         
          
<section class="banner_area">
<div class="banner_inner d-flex align-items-center">
<div class="overlay bg-parallax" data-stellar-ratio="0.9" data-stellar-vertical-offset="0" data-background="" style="transform: translateY(0.163926px);"></div>
<div class="container">
<div class="banner_content text-center">
<h2>Contact Us</h2>
<div class="page_link">
<a href="/">Home</a>
<a href="/contactus">Contact</a>
</div>
</div>
</div>
</div>
</section>
<!--section form-->
<section class="contact_area p_120">
 <div class="container">

<div class="row">
<div class="col-lg-3">
<div class="contact_info">
<div class="info_item">
<i class="lnr lnr-home"></i>
<h6>Bydgoszcz, Poland</h6>
<p>Q4Ski Ltd., ul. Olowiana 12, 85-461</p>
</div>
<div class="info_item">
<i class="lnr lnr-phone-handset"></i>
<h6><a href="#">+48 601 424 327</a></h6>
<p>Mon to Fri 9am to 6 pm</p>
</div>
<div class="info_item">
<i class="lnr lnr-envelope"></i>
<h6><a href="#">office@q4ski.com</a></h6>
<p>Send us your query anytime!</p>
</div>
</div>
</div>
<div class="col-lg-9">
<div t-ignore="true">
<form class="row contact_form s_website_form container-fluid mt32" action="/website_form/" method="post" data-model_name="crm.lead" data-success_page="/contactus-thank-you" enctype="multipart/form-data" data-editable-form="false">
<div class="col-md-6">
<div class="form-group">
<input type="text" class="form-control o_website_form_input" id="contact_name" name="contact_name" placeholder="Enter your name" t-att-value="request.params.get('contact_name', '')" required=""/>
</div>
<div class="form-group">
<input type="text" class="form-control o_website_form_input" id="email_from" name="email_from" placeholder="Enter email address" required="" t-att-value="request.params.get('email_from', '')"/>
</div>
<div class="form-group">
<input type="text" class="form-control o_website_form_input" id="name" name="name" placeholder="Enter Subject" required="" t-att-value="request.params.get('name', '')"/>
</div>
</div>
<div class="col-md-6">
<div class="form-group">
<textarea class="form-control o_website_form_input" name="description" id="description" rows="1" placeholder="Enter Message" required=""><t t-esc="request.params.get('description', '')"/></textarea>
</div>
</div>
<div class="col-md-12 text-right">
<button href="#" role="button" class="btn submit_btn o_website_form_send">Send Message</button>
<span id="o_website_form_result"/>
</div>
</form>
</div>
</div>
</div>
</div>
</section>
<section class="map1 cid-qv5AtTlAOw" id="map1-30" data-rv-view="10266">

     

    <div class="google-map"><iframe frameborder="0" style="border:0" src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2392.8993544117266!2d17.904627315093144!3d53.14790079725888!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47030ded851830d7%3A0xa16e06b69b0c30a4!2sO%C5%82owiana%2012%2C%2085-461%20Bydgoszcz%2C%20Pologne!5e0!3m2!1sfr!2sdz!4v1600535361988!5m2!1sfr!2sdz" allowfullscreen=""></iframe></div>

</section>
<!--section-->



        </xpath>
      </template>


    <template id="assets_frontendcontact" name="contact assets" inherit_id="theme_caski.contact_caski">
        <xpath expr="." position="inside">
         	<link rel="stylesheet" type="text/css" href="/theme_caski/static/src/css/contact.css"/>
        </xpath>
    </template>


</odoo>
